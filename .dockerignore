# Version control
.git
.gitignore
.github

# Editor / OS
.vscode
.DS_Store
.idea
.project
.settings
*.iml
Thumbs.db
*.swp
*.swo
*~

# Secrets - never copy into image
.env
.env.local
.env.*.local
*.pem
*.key

# Node
node_modules
npm-debug.log
package-lock.json
yarn.lock

# Build artifacts
build/
dist/
coverage/
.nyc_output/
.cache/
.eslintcache
tmp/
temp/

# Logs
*.log

# CI/CD docs (not needed at runtime)
Jenkinsfile
.github/
.gitlab-ci.yml
.travis.yml
DOCKER_JENKINS_GUIDE.md
DOCKER_JENKINS_SETUP_COMPLETE.md
README.md
CONTRIBUTING.md
LICENSE

# Test files
tests/
test/
*.test.php
phpunit.xml

# NOTE: docker/ and docker-compose.yml are intentionally NOT excluded here.
# The Dockerfile uses explicit COPY docker/xxx instructions which Docker
# resolves before .dockerignore filtering; keeping them in context avoids
# "not found" cache-key errors during cloud builds.
