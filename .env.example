# EqualVoice Docker / CI/CD Environment
# Copy to .env and update with your values

# ========================================
# Database Configuration
# ========================================
DB_HOST=mysql
DB_NAME=equalvoice_db
DB_USER=equalvoice_user
DB_PASS=user_password_456
DB_ROOT_PASSWORD=root_password_123

# ========================================
# Jenkins Configuration
# ========================================
JENKINS_URL=http://localhost:9090
JENKINS_USER=admin
JENKINS_API_TOKEN=your-jenkins-api-token-here
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin123
JENKINS_JAVA_OPTIONS=-Xmx2048m

# ========================================
# GitHub Configuration
# ========================================
GITHUB_TOKEN=your-github-personal-access-token
GIT_BRANCH=main
GITHUB_REPO=sheniahbucoy08-ui/equality
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ========================================
# Docker Registry (optional — monolithic pipeline)
# ========================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# ========================================
# Application
# ========================================
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
COMPOSE_PROJECT_NAME=equalvoice
SERVER_PORT=80
PHPMYADMIN_PORT=8081

# ========================================
# Build metadata (CI injects these)
# ========================================
BUILD_DATE=unknown
VCS_REF=unknown
BUILD_VERSION=dev
